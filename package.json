{
  "name": "fetch",
  "version": "0.1.0",
  "private": true,
  "description": "Fetch — an open-source, self-hostable GTM operating system.",
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* run build && pnpm -r --filter=./apps/* run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "dev:api": "pnpm --filter @fetch/api dev",
    "dev:worker": "pnpm --filter @fetch/worker dev",
    "dev:web": "pnpm --filter @fetch/web dev",
    "db:generate": "pnpm --filter @fetch/db generate",
    "db:migrate": "pnpm --filter @fetch/db migrate",
    "db:studio": "pnpm --filter @fetch/db studio",
    "seed": "tsx scripts/seed.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}
