# ─────────────────────────────────────────────────────────────────────────────
# Fetch — environment template
# Copy to `.env` and fill in. The app fails fast if a required var is missing.
# The minimum viable deploy is ONE Postgres + the app: only DATABASE_URL is
# strictly required to boot. Everything else unlocks a capability.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core (required) ──────────────────────────────────────────────────────────
# Single source of truth. Postgres also hosts the pg-boss job queue (no Redis).
DATABASE_URL=postgres://fetch:fetch@localhost:5432/fetch

# Where the API listens, and where the web UI expects to find it.
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Worker concurrency per queue.
WORKER_CONCURRENCY=4

# Optional API bearer token. Leave empty for an open single-tenant self-host;
# set it to require `Authorization: Bearer <token>` on data routes (/health and
# /webhooks/* stay exempt — webhooks authenticate by signature).
FETCH_API_TOKEN=

# ── LLM layer (provider-agnostic) ────────────────────────────────────────────
# Pick a default provider; supply that provider's key. Used by the agent loop
# (enrichment fallback) and personalization.
#
# Any model id works here (it's also overridable per-Dogi via the brain picker).
# The OpenAI default below is a *-search-preview model: web search is built in, so
# Dogi/Bone get real, cited web results out of the box (costs more than -mini).
LLM_PROVIDER=openai               # anthropic | openai | gemini | grok
LLM_MODEL=gpt-4o-mini-search-preview   # built-in web search; or e.g. gpt-4.1, claude-opus-4-8
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Enrichment providers (waterfall, cheapest first) ─────────────────────────
APOLLO_API_KEY=
HUNTER_API_KEY=
FINDYMAIL_API_KEY=
DROPCONTACT_API_KEY=

# ── Agent tools: web search + scrape ─────────────────────────────────────────
# Two pluggable backends, each with a self-hosted (free, no key) option that
# takes precedence over the hosted API key. See docker-compose.search.yml and
# devx/RUN-search-stack.md to bring the self-hosted services up.
#
# WEB SEARCH precedence:  OPENSERP_URL  >  SERPER_API_KEY  >  (web_search off)
# SCRAPE     precedence:  FIRECRAWL_API_URL  >  FIRECRAWL_API_KEY  >  (scrape off)

# Self-hosted SERP (OpenSERP) — free, no API key. When set, used over Serper.
OPENSERP_URL=                     # e.g. http://localhost:7001
# Engine OpenSERP drives: google | yandex | baidu.
# NOTE: Google needs a non-datacenter (residential) IP — from a server/datacenter
# IP it gets CAPTCHA-blocked (429 captcha_detected). Default to yandex for local.
# Yandex also rate-limits under heavy use, so space requests / cache results.
OPENSERP_ENGINE=yandex
SERPER_API_KEY=                   # hosted web_search fallback (used if OPENSERP_URL unset)

# Self-hosted Firecrawl scrape → markdown. When set, used over the hosted key.
FIRECRAWL_API_URL=                # e.g. http://localhost:3002
FIRECRAWL_API_KEY=                # hosted scrape fallback (or auth for a secured self-host)

# ── Validation ───────────────────────────────────────────────────────────────
# Reacher does SMTP/mailbox reachability. MX + syntax + disposable run locally.
REACHER_URL=                      # e.g. http://localhost:8080

# ── Send rails ───────────────────────────────────────────────────────────────
INSTANTLY_API_KEY=
INSTANTLY_WEBHOOK_SECRET=
SMARTLEAD_API_KEY=
SMARTLEAD_WEBHOOK_SECRET=

# Generic SMTP rail (optional fallback sender).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
