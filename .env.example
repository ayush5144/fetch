# ─────────────────────────────────────────────────────────────────────────────
# Fetch — environment template
# Copy to `.env` and fill in. The app fails fast if a required var is missing.
# The minimum viable deploy is ONE Postgres + the app: only DATABASE_URL is
# strictly required to boot. Everything else unlocks a capability.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core (required) ──────────────────────────────────────────────────────────
# Single source of truth. Postgres also hosts the pg-boss job queue (no Redis).
DATABASE_URL=postgres://fetch:fetch@localhost:5432/fetch

# Where the API listens, and where the web UI expects to find it.
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Worker concurrency per queue.
WORKER_CONCURRENCY=4

# ── LLM layer (provider-agnostic) ────────────────────────────────────────────
# Pick a default provider; supply that provider's key. Used by the agent loop
# (enrichment fallback) and personalization.
LLM_PROVIDER=anthropic            # anthropic | openai
LLM_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Enrichment providers (waterfall, cheapest first) ─────────────────────────
APOLLO_API_KEY=
HUNTER_API_KEY=
FINDYMAIL_API_KEY=
DROPCONTACT_API_KEY=

# ── Agent tools ──────────────────────────────────────────────────────────────
SERPER_API_KEY=                   # web_search
FIRECRAWL_API_KEY=                # scrape_url / extract_field

# ── Validation ───────────────────────────────────────────────────────────────
# Reacher does SMTP/mailbox reachability. MX + syntax + disposable run locally.
REACHER_URL=                      # e.g. http://localhost:8080

# ── Send rails ───────────────────────────────────────────────────────────────
INSTANTLY_API_KEY=
INSTANTLY_WEBHOOK_SECRET=
SMARTLEAD_API_KEY=
SMARTLEAD_WEBHOOK_SECRET=

# Generic SMTP rail (optional fallback sender).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
